"use client";

import { useEffect, useState, useCallback } from "react";
import { useRouter } from "next/navigation";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { ScrollArea } from "@/components/ui/scroll-area";
import { Badge } from "@/components/ui/badge";
import { Plus, Minus, Trash, MagnifyingGlass, ArrowLeft } from "@phosphor-icons/react";
import { toast } from "sonner";
import type { Product, Category, CartItem, Frosting, DryTopping, Extra } from "@/lib/types";
import { EmployeePinModal } from "@/components/employee-pin-modal";

type Step = "products" | "frosting" | "dryTopping" | "extras";

export default function BarPage() {
  const router = useRouter();
  
  // Data
  const [products, setProducts] = useState<Product[]>([]);
  const [categories, setCategories] = useState<Category[]>([]);
  const [frostings, setFrostings] = useState<Frosting[]>([]);
  const [dryToppings, setDryToppings] = useState<DryTopping[]>([]);
  const [extras, setExtras] = useState<Extra[]>([]);
  
  // Navigation
  const [currentStep, setCurrentStep] = useState<Step>("products");
  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);
  const [selectedFrosting, setSelectedFrosting] = useState<{ id: string | null; name: string | null }>({ id: null, name: null });
  const [selectedDryTopping, setSelectedDryTopping] = useState<{ id: string | null; name: string | null }>({ id: null, name: null });
  
  // Filters
  const [selectedCategory, setSelectedCategory] = useState<string | null>(null);
  const [searchQuery, setSearchQuery] = useState("");
  
  // Cart & State
  const [cart, setCart] = useState<CartItem[]>([]);
  const [loading, setLoading] = useState(true);
  const [submitting, setSubmitting] = useState(false);
  const [employeeId, setEmployeeId] = useState<string | null>(null);
  const [pinModalOpen, setPinModalOpen] = useState(false);

  useEffect(() => {
    // Solicitar PIN al inicio (identificación del cajero)
    setPinModalOpen(true);
  }, []);

  async function fetchData() {
    try {
      const [productsRes, categoriesRes, frostingsRes, dryToppingsRes, extrasRes] = await Promise.all([
        fetch("/api/products?active=true"),
        fetch("/api/categories"),
        fetch("/api/frostings?active=true"),
        fetch("/api/dry-toppings?active=true"),
        fetch("/api/extras?active=true"),
      ]);
      if (productsRes.ok) setProducts(await productsRes.json());
      if (categoriesRes.ok) setCategories(await categoriesRes.json());
      if (frostingsRes.ok) setFrostings(await frostingsRes.json());
      if (dryToppingsRes.ok) setDryToppings(await dryToppingsRes.json());
      if (extrasRes.ok) setExtras(await extrasRes.json());
    } catch (error) {
      toast.error("Error cargando datos");
    } finally {
      setLoading(false);
    }
  }

  const filteredProducts = products.filter((p) => {
    const matchesCategory = !selectedCategory || p.categoryId === selectedCategory;
    const matchesSearch = !searchQuery || p.name.toLowerCase().includes(searchQuery.toLowerCase());
    return matchesCategory && matchesSearch;
  });

  function handleProductSelect(product: Product) {
    setSelectedProduct(product);
    setCurrentStep("frosting");
  }

  function handleFrostingSelect(frostingId: string | null, frostingName: string | null) {
    setSelectedFrosting({ id: frostingId, name: frostingName });
    setCurrentStep("dryTopping");
  }

  function handleDryToppingSelect(dryToppingId: string | null, dryToppingName: string | null) {
    setSelectedDryTopping({ id: dryToppingId, name: dryToppingName });
    setCurrentStep("extras");
  }

  function handleExtraSelect(extraId: string | null, extraName: string | null, extraPrice: number = 0) {
    if (!selectedProduct) return;

    const finalPrice = parseFloat(selectedProduct.price) + extraPrice;

    setCart((prev) => {
      const key = `${selectedProduct.id}-${selectedFrosting.id}-${selectedDryTopping.id}-${extraId}`;
      const existing = prev.find(
        (item) =>
          item.productId === selectedProduct.id &&
          item.frostingId === selectedFrosting.id &&
          item.dryToppingId === selectedDryTopping.id &&
          item.extraId === extraId
      );

      if (existing) {
        return prev.map((item) =>
          item.productId === selectedProduct.id &&
          item.frostingId === selectedFrosting.id &&
          item.dryToppingId === selectedDryTopping.id &&
          item.extraId === extraId
            ? { ...item, quantity: item.quantity + 1 }
            : item
        );
      }

      return [
        ...prev,
        {
          productId: selectedProduct.id,
          productName: selectedProduct.name,
          unitPrice: finalPrice,
          quantity: 1,
          notes: "",
          frostingId: selectedFrosting.id,
          frostingName: selectedFrosting.name,
          dryToppingId: selectedDryTopping.id,
          dryToppingName: selectedDryTopping.name,
          extraId,
          extraName,
        },
      ];
    });

    // Reset and go back to products
    setSelectedProduct(null);
    setSelectedFrosting({ id: null, name: null });
    setSelectedDryTopping({ id: null, name: null });
    setCurrentStep("products");
    toast.success("Agregado al carrito");
  }

  function goBack() {
    if (currentStep === "frosting") {
      setSelectedProduct(null);
      setCurrentStep("products");
    } else if (currentStep === "dryTopping") {
      setCurrentStep("frosting");
    } else if (currentStep === "extras") {
      setCurrentStep("dryTopping");
    }
  }

  const updateQuantity = useCallback((index: number, delta: number) => {
    setCart((prev) =>
      prev
        .map((item, i) =>
          i === index ? { ...item, quantity: Math.max(0, item.quantity + delta) } : item
        )
        .filter((item) => item.quantity > 0)
    );
  }, []);

  const removeItem = useCallback((index: number) => {
    setCart((prev) => prev.filter((_, i) => i !== index));
  }, []);

  const cartTotal = cart.reduce((sum, item) => sum + item.unitPrice * item.quantity, 0);

  function initiateOrder() {
    if (cart.length === 0) {
      toast.error("Agrega al menos un producto");
      return;
    }

    if (!employeeId) {
      toast.error("No hay cajero identificado");
      return;
    }

    handleSubmitOrder();
  }

  async function handleSubmitOrder() {
    if (!employeeId) return;
    
    setSubmitting(true);

    try {
      const res = await fetch("/api/orders", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ items: cart, userId: employeeId }),
      });

      if (!res.ok) throw new Error();

      const order = await res.json();
      toast.success(`Orden #${order.orderNumber} creada`);
      
      setCart([]);
      router.push(`/orders/pay/${order.id}`);
    } catch (error) {
      toast.error("Error creando orden");
    } finally {
      setSubmitting(false);
    }
  }

  function handlePinSuccess(empId: string, empName: string) {
    setEmployeeId(empId);
    setPinModalOpen(false);
    toast.success(`Bienvenido, ${empName}`);
    // Cargar datos después de autenticación
    fetchData();
  }

  const formatCurrency = (amount: number) =>
    new Intl.NumberFormat("es-MX", { style: "currency", currency: "MXN" }).format(amount);

  if (loading) {
    return (
      <div className="flex h-screen items-center justify-center">
        Cargando...
      </div>
    );
  }

  return (
    <div className="flex h-screen bg-neutral-50">
      {/* Main Content Area */}
      <div className="flex-1 flex flex-col">
        {/* Header */}
        <div className="border-b bg-white p-4">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              {currentStep !== "products" && (
                <Button variant="ghost" size="sm" onClick={goBack}>
                  <ArrowLeft className="size-4" />
                </Button>
              )}
              <div>
                <h1 className="text-xl font-semibold text-neutral-900">
                  {currentStep === "products" && "Selecciona Bebida"}
                  {currentStep === "frosting" && `${selectedProduct?.name} - Escarchado`}
                  {currentStep === "dryTopping" && `${selectedProduct?.name} - Escarchado Seco`}
                  {currentStep === "extras" && `${selectedProduct?.name} - Extras`}
                </h1>
                <p className="text-xs text-neutral-500">
                  {currentStep === "products" && "Paso 1 de 4"}
                  {currentStep === "frosting" && "Paso 2 de 4"}
                  {currentStep === "dryTopping" && "Paso 3 de 4"}
                  {currentStep === "extras" && "Paso 4 de 4"}
                </p>
              </div>
            </div>
            {currentStep === "products" && (
              <Badge variant="secondary">{cart.length} items</Badge>
            )}
          </div>
        </div>

        {/* Content */}
        <div className="flex-1 overflow-hidden">
          {/* STEP 1: Products */}
          {currentStep === "products" && (
            <div className="h-full flex flex-col">
              <div className="border-b p-4 space-y-3">
                <div className="relative">
                  <MagnifyingGlass className="absolute left-3 top-1/2 size-4 -translate-y-1/2 text-neutral-400" />
                  <Input
                    placeholder="Buscar bebidas..."
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                    className="pl-10"
                  />
                </div>

                <div className="flex flex-wrap gap-2">
                  <Button
                    variant={selectedCategory === null ? "default" : "outline"}
                    size="sm"
                    onClick={() => setSelectedCategory(null)}
                  >
                    Todos
                  </Button>
                  {categories.map((cat) => (
                    <Button
                      key={cat.id}
                      variant={selectedCategory === cat.id ? "default" : "outline"}
                      size="sm"
                      onClick={() => setSelectedCategory(cat.id)}
                    >
                      {cat.name}
                    </Button>
                  ))}
                </div>
              </div>

              <ScrollArea className="flex-1 p-4">
                <div className="grid grid-cols-3 gap-3">
                  {filteredProducts.map((product) => (
                    <Card
                      key={product.id}
                      className="cursor-pointer hover:shadow-md transition-shadow overflow-hidden"
                      onClick={() => handleProductSelect(product)}
                    >
                      {product.imageUrl && (
                        <div className="aspect-square bg-neutral-100 overflow-hidden">
                          <img
                            src={product.imageUrl}
                            alt={product.name}
                            className="w-full h-full object-cover"
                          />
                        </div>
                      )}
                      <CardContent className="p-4">
                        <h3 className="font-medium text-sm mb-2">{product.name}</h3>
                        <p className="text-lg font-bold text-neutral-900">
                          {formatCurrency(parseFloat(product.price))}
                        </p>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </ScrollArea>
            </div>
          )}

          {/* STEP 2: Frosting */}
          {currentStep === "frosting" && (
            <ScrollArea className="h-full p-4">
              <div className="grid grid-cols-3 gap-3 max-w-4xl mx-auto">
                <Card
                  className="cursor-pointer hover:shadow-md transition-shadow border-2"
                  onClick={() => handleFrostingSelect(null, null)}
                >
                  <CardContent className="p-6 text-center">
                    <p className="font-medium text-neutral-600">Ninguno</p>
                  </CardContent>
                </Card>

                {frostings.map((frosting) => (
                  <Card
                    key={frosting.id}
                    className="cursor-pointer hover:shadow-md transition-shadow"
                    onClick={() => handleFrostingSelect(frosting.id, frosting.name)}
                  >
                    <CardContent className="p-6">
                      <p className="font-medium">{frosting.name}</p>
                      {frosting.description && (
                        <p className="text-xs text-neutral-500 mt-1">{frosting.description}</p>
                      )}
                    </CardContent>
                  </Card>
                ))}
              </div>
            </ScrollArea>
          )}

          {/* STEP 3: Dry Topping */}
          {currentStep === "dryTopping" && (
            <ScrollArea className="h-full p-4">
              <div className="grid grid-cols-3 gap-3 max-w-4xl mx-auto">
                <Card
                  className="cursor-pointer hover:shadow-md transition-shadow border-2"
                  onClick={() => handleDryToppingSelect(null, null)}
                >
                  <CardContent className="p-6 text-center">
                    <p className="font-medium text-neutral-600">Ninguno</p>
                  </CardContent>
                </Card>

                {dryToppings.map((topping) => (
                  <Card
                    key={topping.id}
                    className="cursor-pointer hover:shadow-md transition-shadow"
                    onClick={() => handleDryToppingSelect(topping.id, topping.name)}
                  >
                    <CardContent className="p-6">
                      <p className="font-medium">{topping.name}</p>
                      {topping.description && (
                        <p className="text-xs text-neutral-500 mt-1">{topping.description}</p>
                      )}
                    </CardContent>
                  </Card>
                ))}
              </div>
            </ScrollArea>
          )}

          {/* STEP 4: Extras */}
          {currentStep === "extras" && (
            <ScrollArea className="h-full p-4">
              <div className="grid grid-cols-3 gap-3 max-w-4xl mx-auto">
                <Card
                  className="cursor-pointer hover:shadow-md transition-shadow border-2"
                  onClick={() => handleExtraSelect(null, null, 0)}
                >
                  <CardContent className="p-6 text-center">
                    <p className="font-medium text-neutral-600">Ninguno</p>
                  </CardContent>
                </Card>

                {extras.map((extra) => (
                  <Card
                    key={extra.id}
                    className="cursor-pointer hover:shadow-md transition-shadow"
                    onClick={() => handleExtraSelect(extra.id, extra.name, parseFloat(extra.price))}
                  >
                    <CardContent className="p-6">
                      <p className="font-medium">{extra.name}</p>
                      {extra.description && (
                        <p className="text-xs text-neutral-500 mt-1">{extra.description}</p>
                      )}
                      <p className="text-sm font-semibold text-green-600 mt-2">
                        +{formatCurrency(parseFloat(extra.price))}
                      </p>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </ScrollArea>
          )}
        </div>
      </div>

      {/* Cart Sidebar */}
      <div className="w-80 border-l bg-white flex flex-col">
        <div className="border-b p-4">
          <h2 className="font-semibold text-neutral-900">Carrito</h2>
          <p className="text-xs text-neutral-500">{cart.length} productos</p>
        </div>

        <ScrollArea className="flex-1 p-4">
          {cart.length === 0 ? (
            <div className="flex h-32 items-center justify-center text-neutral-400 text-sm">
              Carrito vacío
            </div>
          ) : (
            <div className="space-y-2">
              {cart.map((item, idx) => (
                <div key={idx} className="rounded-lg border p-2 space-y-2 bg-neutral-50">
                  <div className="flex items-start justify-between">
                    <div className="flex-1 text-xs">
                      <p className="font-medium text-neutral-900">{item.productName}</p>
                      {item.frostingName && (
                        <p className="text-blue-600">Escarchado: {item.frostingName}</p>
                      )}
                      {item.dryToppingName && (
                        <p className="text-orange-600">Seco: {item.dryToppingName}</p>
                      )}
                      {item.extraName && (
                        <p className="text-green-600">Extra: {item.extraName}</p>
                      )}
                      <p className="text-neutral-500">{formatCurrency(item.unitPrice)} c/u</p>
                    </div>
                    <Button variant="ghost" size="sm" onClick={() => removeItem(idx)}>
                      <Trash className="size-3 text-destructive" />
                    </Button>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button
                      variant="outline"
                      size="sm"
                      onClick={() => updateQuantity(idx, -1)}
                    >
                      <Minus className="size-3" />
                    </Button>
                    <span className="w-6 text-center text-xs font-medium">{item.quantity}</span>
                    <Button
                      variant="outline"
                      size="sm"
                      onClick={() => updateQuantity(idx, 1)}
                    >
                      <Plus className="size-3" />
                    </Button>
                    <span className="ml-auto font-semibold text-xs">
                      {formatCurrency(item.unitPrice * item.quantity)}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          )}
        </ScrollArea>

        {cart.length > 0 && (
          <div className="border-t p-4 space-y-3 bg-neutral-50">
            <div className="flex items-center justify-between text-lg font-bold">
              <span>Total</span>
              <span>{formatCurrency(cartTotal)}</span>
            </div>
            <Button
              className="w-full"
              size="lg"
              onClick={initiateOrder}
              disabled={submitting}
            >
              {submitting ? "Procesando..." : "Cobrar"}
            </Button>
          </div>
        )}
      </div>

      <EmployeePinModal
        open={pinModalOpen}
        onClose={() => {
          setPinModalOpen(false);
          // Si cierra sin autenticarse, no puede usar la vista
          if (!employeeId) {
            toast.error("Debes identificarte para usar esta caja");
          }
        }}
        onSuccess={handlePinSuccess}
        title="Inicio de Turno"
        subtitle="Ingresa tu PIN para identificarte como cajero"
      />
    </div>
  );
}
